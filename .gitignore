# =============================================================================
# Kubernetes学習プロジェクト .gitignore
# =============================================================================

# -------------------------------------
# シークレット・認証情報 (絶対にコミットしない)
# -------------------------------------
*.secret.yaml
*.secret.yml
secrets.yaml
secrets.yml
*-secret-override.yaml

# Helm シークレット上書きファイル
helm/values/*.secret.yaml
helm/values/secrets.yaml

# 環境変数ファイル
.env
.env.*
!.env.example

# 証明書・秘密鍵
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks

# kubeconfig (クラスタ認証情報を含む)
kubeconfig
kubeconfig.*
.kube/

# AWSクレデンシャル
.aws/credentials
credentials

# -------------------------------------
# ツール生成ファイル
# -------------------------------------

# Helmテンプレートの展開結果
helm-rendered/
*.rendered.yaml

# istioctl ダウンロードディレクトリ
istio-*/

# -------------------------------------
# OS・エディタ生成ファイル
# -------------------------------------
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/
*.swp
*.swo

# -------------------------------------
# ログ・一時ファイル
# -------------------------------------
*.log
tmp/
temp/
